<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Join the Chamber of Commerce - Gaborone Tech Startups Chamber of Commerce</title>
    <link rel="stylesheet" href="styles/normalize.css">
    <link rel="stylesheet" href="styles/styles.css">
</head>
<body>
    <!-- Header -->
    <header>
        <h1>Gaborone Tech Startups Chamber of Commerce</h1>
        <nav>
            <ul>
                <li><a href="index.html">Home</a></li>
                <li><a href="discover.html">Discover</a></li>
                <li><a href="directory.html">Business Directory</a></li>
                <li><a href="join.html">Join</a></li>
                <li><a href="about.html">About</a></li>
                <li><a href="podcast.html">Podcast</a></li>
                <li><a href="events.html">Events</a></li>
            </ul>
        </nav>
    </header>

    <!-- Main Content -->
    <main>
        <h2>Join the Chamber of Commerce</h2>
        <form action="thankyou.html" method="get">
            <label for="first-name">
                First Name:
                <input type="text" id="first-name" name="first-name" title="First Name" autocomplete="given-name" required>
            </label>
            <label for="last-name">
                Last Name:
                <input type="text" id="last-name" name="last-name" title="Last Name" autocomplete="family-name" required>
            </label>
            <label for="organization-title">
                Organizational Title:
                <input type="text" id="organization-title" name="organization-title" title="Organizational Title" autocomplete="organization-title" pattern="[A-Za-z-\s]{7,}" required>
            </label>
            <label for="email">
                Email:
                <input type="email" id="email" name="email" title="Email Address" autocomplete="email" placeholder="example@example.com" required>
            </label>
            <label for="phone">
                Mobile Phone:
                <input type="tel" id="phone" name="phone" title="Mobile Phone Number" autocomplete="tel" required>
            </label>
            <label for="organization">
                Business/Organization Name:
                <input type="text" id="organization" name="organization" title="Business/Organization Name" autocomplete="organization" required>
            </label>
            <label for="membership-level">
                Membership Level:
                <select id="membership-level" name="membership-level" title="Membership Level" required>
                    <option value="" disabled selected>Select your membership level</option>
                    <option value="np">NP Membership</option>
                    <option value="bronze">Bronze Membership</option>
                    <option value="silver">Silver Membership</option>
                    <option value="gold">Gold Membership</option>
                </select>
            </label>
            <button type="button" onclick="showModal()">Learn More</button>
            <label for="description">
                Business/Organization Description:
                <textarea id="description" name="description" title="Business/Organization Description"></textarea>
            </label>
            <input type="hidden" id="timestamp" name="timestamp" value="">
            <input type="submit" value="Submit">
        </form>

        <!-- Modal -->
        <div id="modal" class="modal">
            <div class="modal-content">
                <span class="close" onclick="hideModal()">&times;</span>
                <h3>Membership Levels</h3>
                <div class="card-container">
                    <div class="card">
                        <h4>NP Membership</h4>
                        <p>Basic membership for startups.</p>
                    </div>
                    <div class="card">
                        <h4>Silver Membership</h4>
                        <p>Enhanced benefits for growing businesses.</p>
                    </div>
                    <div class="card">
                        <h4>Gold Membership</h4>
                        <p>Premium membership with full benefits.</p>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer>
        <p>&copy; 2024 Gaborone Tech Startups Chamber of Commerce. All rights reserved.</p>
        <p><a href="contact.html">Contact Us</a> | <a href="privacy.html">Privacy Policy</a></p>
    </footer>

    <script>
        function showModal() {
            document.getElementById('modal').style.display = 'block';
        }
        function hideModal() {
            document.getElementById('modal').style.display = 'none';
        }
    </script>
</body>
</html>

